<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="pl.rozowi.app.controllers.ReportsController"
      spacing="15" style="-fx-padding: 15px; -fx-background-color: #1E1E2F;">

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Raporty Systemowe"
               style="-fx-font-size: 24px; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Pane HBox.hgrow="ALWAYS" />
    </HBox>

    <!-- Expanded Report Options Section -->
    <VBox spacing="15" style="-fx-background-color: #252540; -fx-padding: 15px; -fx-background-radius: 5px;">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Typ raportu:" style="-fx-text-fill: white;"/>
            <ComboBox fx:id="reportTypeComboBox" prefWidth="250"/>
            <Button fx:id="filterOptionsButton" text="Opcje filtrowania" onAction="#handleShowFilterOptions"
                    style="-fx-background-color: #17a2b8; -fx-text-fill: white;"/>
        </HBox>

        <!-- Filter Options (initially invisible) -->
        <VBox fx:id="filterOptionsPane" visible="false" spacing="10">
            <TitledPane text="Filtry raportu" expanded="true" style="-fx-text-fill: black;">
                <VBox spacing="10">

                    <HBox spacing="10" alignment="CENTER_LEFT" fx:id="teamsContainer">
                        <Label fx:id="teamsLabel" text="Wybierz zespoły:" style="-fx-text-fill: black;" prefWidth="150"/>
                        <VBox spacing="5">
                            <HBox spacing="5" fx:id="teamsButtonsContainer">
                                <Button text="Zaznacz wszystko" onAction="#handleSelectAllTeams" style="-fx-background-color: #e0e0e0; -fx-text-fill: black;"/>
                                <Button text="Odznacz wszystko" onAction="#handleDeselectAllTeams" style="-fx-background-color: #e0e0e0; -fx-text-fill: black;"/>
                            </HBox>
                            <ListView fx:id="teamsListView" prefHeight="120" prefWidth="300"
                                      style="-fx-text-fill: black;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="projectsLabel" text="Wybierz projekty:" style="-fx-text-fill: black;" prefWidth="150" visible="false" managed="false"/>
                        <VBox spacing="5">
                            <HBox spacing="5">
                                <Button text="Zaznacz wszystko" onAction="#handleSelectAllProjects" style="-fx-background-color: #e0e0e0; -fx-text-fill: black;" visible="false" managed="false" fx:id="selectAllProjectsBtn"/>
                                <Button text="Odznacz wszystko" onAction="#handleDeselectAllProjects" style="-fx-background-color: #e0e0e0; -fx-text-fill: black;" visible="false" managed="false" fx:id="deselectAllProjectsBtn"/>
                            </HBox>
                            <ListView fx:id="projectsListView" prefHeight="120" prefWidth="300"
                                      style="-fx-text-fill: black;" visible="false" managed="false"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="10" alignment="CENTER_LEFT" visible="false" fx:id="userTypesContainer">
                        <Label text="Typy użytkowników:" style="-fx-text-fill: black;" prefWidth="150"/>
                        <VBox spacing="5">
                            <CheckBox fx:id="adminCheckbox" text="Administratorzy" selected="true" style="-fx-text-fill: black;"/>
                            <CheckBox fx:id="managerCheckbox" text="Kierownicy" selected="true" style="-fx-text-fill: black;"/>
                            <CheckBox fx:id="teamLeaderCheckbox" text="Team liderzy" selected="true" style="-fx-text-fill: black;"/>
                            <CheckBox fx:id="userCheckbox" text="Pracownicy" selected="true" style="-fx-text-fill: black;"/>
                        </VBox>
                    </HBox>

                    <!-- Filter 2 -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="dateRangeLabel" text="Zakres dat:" style="-fx-text-fill: black;" prefWidth="150"/>
                        <DatePicker fx:id="startDatePicker" promptText="Data początkowa" prefWidth="150"/>
                        <DatePicker fx:id="endDatePicker" promptText="Data końcowa" prefWidth="150"/>
                    </HBox>

                    <!-- Filter 3 -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Szczegóły raportu:" style="-fx-text-fill: black;" prefWidth="150"/>
                        <VBox spacing="5">
                            <CheckBox fx:id="showTasksCheckbox" text="Pokaż zadania" selected="true" style="-fx-text-fill: black;"/>
                            <CheckBox fx:id="showMembersCheckbox" text="Pokaż członków zespołów" selected="true" style="-fx-text-fill: black;"/>
                            <CheckBox fx:id="showStatisticsCheckbox" text="Pokaż statystyki" selected="true" style="-fx-text-fill: black;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </TitledPane>
        </VBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="generateButton" text="Generuj raport" onAction="#handleGenerateReport"
                style="-fx-background-color: #28a745; -fx-text-fill: black;"/>
        <Button fx:id="saveAsPdfButton" text="Zapisz jako PDF" onAction="#handleSaveAsPdf"
                style="-fx-background-color: #007BFF; -fx-text-fill: black;"/>
    </HBox>

    <!-- Report Content Preview Area -->
    <TextArea fx:id="reportsArea" wrapText="true" editable="false" VBox.vgrow="ALWAYS"
              style="-fx-font-family: monospace;"/>

    <!-- Instructions -->
    <VBox spacing="5" style="-fx-background-color: #252540; -fx-padding: 10px; -fx-background-radius: 5px;">
        <Label text="Instrukcja:" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="1. Wybierz rodzaj raportu z listy rozwijanej." style="-fx-text-fill: white;"/>
        <Label text="2. Kliknij 'Opcje filtrowania' aby dostosować zawartość raportu." style="-fx-text-fill: white;"/>
        <Label text="3. Kliknij 'Generuj raport' aby zobaczyć podgląd." style="-fx-text-fill: white;"/>
        <Label text="4. Użyj przycisku 'Zapisz jako PDF' aby zapisać raport na dysku." style="-fx-text-fill: white;"/>
    </VBox>

</VBox>